# ── ML Model — large binary/data files (too big for GitHub) ──────────────────
# Trained model binary (~1.8 MB)
ml_model/*.pkl
# XGBoost JSON model (~2.8 MB)
ml_model/*.json
!ml_model/feature_columns.json
# Large training datasets (6–7 MB each)
ml_model/rtl_verification_dataset.csv
ml_model/rtl_verification_dataset_clean.csv
# Jupyter notebook outputs (can be very large)
ml_model/*.ipynb

